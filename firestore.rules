rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcı yalnızca kendi belgesini yazabilir; okuma kimlikli herkese açık
    // (arkadaş profili / friendCode araması için gerekli).
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
                    && validProgress(request.resource.data);
      allow delete: if false;

      // Eski model (deprecated) — artık kullanılmıyor; default-deny güvenli.
      // match /friendRequests/{x} { allow read,write: if false; }
    }

    // ARKADAŞLIK MODELİ: friendships/{pairId}
    // Tek belge iki tarafı temsil eder. members dizisindeki uid'ler dışında
    // kimse okuyamaz/yazamaz; istek/kabul/engel akışı kurallarla doğrulanır.
    match /friendships/{pairId} {
      // get: tekil belge erişimi (var olmayan pair'de resource null olur, bu
      // yüzden üyeliği pairId bileşeninden doğrularız -> existence-safe).
      allow get: if request.auth != null
        && request.auth.uid in pairId.split('__');
      // list: sorgular yalnızca üyesi olduğum belgeleri döndürebilir.
      allow list: if request.auth != null && request.auth.uid in resource.data.members;

      // Oluşturma: yalnızca üyelerden biri; 2 üye; ya KENDİ gönderdiği bir
      // 'pending' istek, ya da KENDİ uyguladığı bir 'blocked' kayıt.
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == 2
        && pairId == request.resource.data.members[0] + '__' + request.resource.data.members[1]
        && (
          (request.resource.data.status == 'pending'
           && request.resource.data.requestedBy == request.auth.uid)
          ||
          (request.resource.data.status == 'blocked'
           && request.resource.data.blockedBy == request.auth.uid)
        );

      // Güncelleme: üyeler değişmeden; ya KARŞI taraf 'pending'->'accepted'
      // yapar, ya da bir üye 'blocked' uygular (blockedBy == kendisi).
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members
        && request.resource.data.members == resource.data.members
        && (
          (resource.data.status == 'pending'
           && request.resource.data.status == 'accepted'
           && request.auth.uid != resource.data.requestedBy)
          ||
          (request.resource.data.status == 'blocked'
           && request.resource.data.blockedBy == request.auth.uid)
        );

      // Silme (reddet / arkadaşlıktan çıkar / engeli kaldır): herhangi bir üye.
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;
    }

    function isMember(res) {
      return request.auth != null && res != null
             && request.auth.uid in res.data.members;
    }

    // Ekonomi/skor alanları için makul sınır + ani sıçrama koruması.
    function validProgress(data) {
      return !('progress' in data) || (
        data.progress.diamonds is int
        && data.progress.diamonds >= 0
        && data.progress.diamonds <= 10000000
        && data.progress.globalTrophies is int
        && data.progress.globalTrophies >= 0
        && data.progress.globalTrophies <= 10000000
      );
    }
  }
}
