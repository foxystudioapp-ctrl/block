rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // USERS: Profil bilgileri, skorlar, elmaslar, VIP, avatarlar vb.
    match /users/{userId} {
      // Herkes okuyabilir (Sıralamada isminin/avatarının görünmesi için)
      allow read: if request.auth != null;

      // Sahibi kendi verisini yazabilir/güncelleyebilir VE SİLEBİLİR.
      // (write = create + update + delete) -> hesap silme için ek kural gerekmez.
      allow write: if request.auth != null && request.auth.uid == userId;

      // ARKADAŞLIK İSTEKLERİ (eski model — kullanıcının alt koleksiyonu)
      match /friendRequests/{senderId} {
         allow create: if request.auth != null && request.auth.uid == senderId;
         allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // FRIENDS: Arkadaş listesi (eski model)
    match /friends/{userId} {
      allow read, write: if request.auth != null;
    }

    // FRIENDSHIPS: Uygulamanın GÜNCEL arkadaşlık modeli (friendService.js bunu kullanır).
    // Hesap silmede bu kayıtların da temizlenebilmesi için delete üyelere açık.
    match /friendships/{pairId} {
      allow get: if request.auth != null
        && request.auth.uid in pairId.split('__');
      allow list: if request.auth != null && request.auth.uid in resource.data.members;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == 2
        && pairId == request.resource.data.members[0] + '__' + request.resource.data.members[1]
        && (
          (request.resource.data.status == 'pending'
           && request.resource.data.requestedBy == request.auth.uid)
          ||
          (request.resource.data.status == 'blocked'
           && request.resource.data.blockedBy == request.auth.uid)
        );

      allow update: if request.auth != null
        && request.auth.uid in resource.data.members
        && request.resource.data.members == resource.data.members
        && (
          (resource.data.status == 'pending'
           && request.resource.data.status == 'accepted'
           && request.auth.uid != resource.data.requestedBy)
          ||
          (request.resource.data.status == 'blocked'
           && request.resource.data.blockedBy == request.auth.uid)
        );

      // Hesap & veri silme: herhangi bir üye kendi arkadaşlık kaydını silebilir.
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;
    }
  }
}
